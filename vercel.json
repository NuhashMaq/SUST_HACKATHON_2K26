{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "src/index.py": {
      "maxDuration": 30,
      "excludeFiles": "{tests/**,sample_cases.json,sample_output.json,README_assets/**}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/src/index.py"
    }
  ]
}
